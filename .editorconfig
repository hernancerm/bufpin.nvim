# <https://EditorConfig.org>.

root = true

[*]
charset = utf-8
indent_size = 2
end_of_line = lf
max_line_length = 100
insert_final_newline = true
indent_style = space

[lua/**.lua]
# Align with the Vim help file hard wrap.
# Although not all Lua files are used to generate docs this keeps consistency.
max_line_length = 82

[lua/bufpin/hsluv.lua]
max_line_length = 0

[Makefile]
indent_style = tab
indent_size = 4
